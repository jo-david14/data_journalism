# ── Cell 2 : Imports
cells.append(code("""import pandas as pd
import numpy as np
import plotly.graph_objects as go
import plotly.express as px
import json, os, warnings
warnings.filterwarnings('ignore')

# ── Design system du site
ROUGE       = '#C0392B'
ROUGE_FONCE = '#7B0000'
BLEU        = '#2C3E50'
OCRE        = '#D4A853'
CREAM       = '#FAFAF8'
GRIS        = '#E8E8E4'
NOIR        = '#1A1A1A'
FONT_T      = 'Georgia, serif'
FONT_B      = 'Arial, sans-serif'

os.makedirs('charts', exist_ok=True)
print('✅ Imports OK')"""))

# ── Cell 3 : Load data
cells.append(code("""# ⚠️ Adapter ce chemin si nécessaire
DATA_PATH = 'kdhs_2022_data_maternal_mortality.csv'

df = pd.read_csv(DATA_PATH)
df['died'] = (df['maternal_death'] == 'Yes').astype(int)

# Groupes d'âge et de parité
df['age_group'] = pd.cut(df['age'],
    bins=[14,18,20,25,30,35,40,50],
    labels=['15-17','18-19','20-24','25-29','30-34','35-39','40+'])

df['parity_group'] = pd.cut(df['parity'],
    bins=[0,1,2,3,5,10],
    labels=['1er','2e','3e','4-5e','6+'])

print(f'✅ Base chargée : {df.shape[0]:,} lignes × {df.shape[1]} colonnes')
print(f'   Décès : {df[\"died\"].sum()} ({df[\"died\"].mean()*100:.1f}%)')"""))

# ── Cell 4 : Helper
cells.append(code("""def base_layout(title, subtitle=''):
    return dict(
        title=dict(
            text=f'<b>{title}</b>' + (f'<br><span style=\"font-size:13px;color:#666\">{subtitle}</span>' if subtitle else ''),
            font=dict(family=FONT_T, size=20, color=NOIR),
            x=0, xanchor='left'
        ),
        paper_bgcolor=CREAM,
        plot_bgcolor=CREAM,
        font=dict(family=FONT_B, color=NOIR),
        margin=dict(l=60, r=40, t=90, b=60),
        hoverlabel=dict(bgcolor=NOIR, font_color='white', font_family=FONT_B, font_size=13, bordercolor=NOIR)
    )

def save_fig(fig, nom):
    path = f'charts/{nom}.json'
    with open(path, 'w') as f:
        json.dump(fig.to_dict(), f)
    print(f'✅ {nom}.json sauvegardé')

print('✅ Helpers prêts')"""))

# ── Cell 5 : Heatmap
cells.append(md("## 1. Heatmap Âge × Parité — Le résultat le plus fort"))
cells.append(code("""age_order    = ['15-17','18-19','20-24','25-29','30-34','35-39','40+']
parite_order = ['1er','2e','3e','4-5e','6+']
parite_labels = ['1er enfant','2e enfant','3e enfant','4e-5e','6e et +']

pivot = df.groupby(['age_group','parity_group'], observed=True)['died'].mean().unstack() * 100
pivot = pivot.reindex(index=age_order, columns=parite_order)

fig1 = go.Figure(go.Heatmap(
    z=pivot.values,
    x=parite_labels,
    y=age_order,
    colorscale=[[0,'#FADBD8'],[0.3,'#F1948A'],[0.6,'#E74C3C'],[0.8,ROUGE],[1,ROUGE_FONCE]],
    hoverongaps=False,
    hovertemplate='<b>Âge :</b> %{y}<br><b>Parité :</b> %{x}<br><b>Taux de mortalité :</b> %{z:.1f}%<extra></extra>',
    text=pivot.values.round(1),
    texttemplate='%{text}%',
    textfont=dict(size=11, color=NOIR),
    colorbar=dict(title=dict(text='Taux (%)'), ticksuffix='%', thickness=15)
))
fig1.update_layout(**base_layout(
    'Mortalité maternelle : Âge × Nombre d\'enfants',
    'Les adolescentes avec 6 enfants ou plus atteignent 60% de mortalité — 6 fois la moyenne nationale'
))
save_fig(fig1, 'heatmap_age_parite')
fig1.show()"""))

